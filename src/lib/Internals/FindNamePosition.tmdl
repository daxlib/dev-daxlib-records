/// Get the position of a parameter name within the encoded string, which can be used to determine if it exists and where its value starts
/// Format: name1[AS]value1[IS]name2[AS]value2[IS]
/// [AS] = Assignment Separator - separates name from value
/// [IS] = Item Separator - separates pairs
/// @param {string} encodedString - The encoded parameter string
/// @param {string} parameterName - The name of the parameter to find
/// @return Character position of the parameter name within the encoded string
function 'DaxLib.Records.Internals.FindNamePosition' = ```
    (
        encodedString : STRING VAL,
        parameterName : STRING VAL
    ) =>
    VAR AssignmentSeparator = DaxLib.Records.Internals.AssignmentSeparator()
    VAR ItemSeparator = DaxLib.Records.Internals.ItemSeparator()

    // Normalize string to ensure trailing item separator
    VAR NormalizedString = DaxLib.Records.Internals.GetNormalizedString(encodedString)

    // Search for the parameter name followed by assignment separator
    VAR SearchPattern = parameterName & AssignmentSeparator
    VAR NamePosition = FIND(SearchPattern, NormalizedString, 1, 0)

    RETURN NamePosition
    ```
    annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__
    annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__
