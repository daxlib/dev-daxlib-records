/// Create an encoded parameter string with three argument/value pairs
/// @param {string} parameterName1 - The name of the first parameter
/// @param {string} parameterValue1 - The value of the first parameter
/// @param {string} parameterName2 - The name of the second parameter
/// @param {string} parameterValue2 - The value of the second parameter
/// @param {string} parameterName3 - The name of the third parameter
/// @param {string} parameterValue3 - The value of the third parameter
/// @return String with the values of the parameters
function 'DaxLib.Records.NewRecordValue3' = ```
    (
        parameterName1 : STRING VAL,
        parameterValue1 : STRING VAL,
        parameterName2 : STRING VAL,
        parameterValue2 : STRING VAL,
        parameterName3 : STRING VAL,
        parameterValue3 : STRING VAL
    ) =>
    DaxLib.Records.AddRecordValue (
        DaxLib.Records.NewRecordValue2 (
            parameterName1, parameterValue1, parameterName2, parameterValue2
        ), parameterName3, parameterValue3
    )
    ```
    annotation DAXLIB_PackageId = __PLACEHOLDER_PACKAGE_ID__
    annotation DAXLIB_PackageVersion = __PLACEHOLDER_PACKAGE_VERSION__
