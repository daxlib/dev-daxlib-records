        parameterValue8 : STRING VAL,
        parameterName9 : STRING VAL,
        parameterValue9 : STRING VAL,
        parameterName10 : STRING VAL,
        parameterValue10 : STRING VAL,
        parameterName11 : STRING VAL,
        parameterValue11 : STRING VAL
    ) =>
    DaxLib.Records.AddRecordValue (
        DaxLib.Records.NewRecordValue10 (
            parameterName1, parameterValue1, parameterName2, parameterValue2, parameterName3, parameterValue3, parameterName4, parameterValue4, parameterName5, parameterValue5, parameterName6, parameterValue6, parameterName7, parameterValue7, parameterName8, parameterValue8, parameterName9, parameterValue9, parameterName10, parameterValue10
